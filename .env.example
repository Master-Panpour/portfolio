# Copy this file to .env for local development.
# Never commit the real .env file.

# Backend server
PORT=8080
PORTFOLIO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORTFOLIO_DATA_PATH=data/profile.json
PORTFOLIO_ACCESS_LOG_PATH=data/access-log.jsonl
PORTFOLIO_THM_CACHE_PATH=data/thm-rooms.json

# Nyxora admin portal
# Generate a long random value and keep it private.
PORTFOLIO_ADMIN_TOKEN=

# Optional TryHackMe live feed
PORTFOLIO_THM_FEED_URL=
PORTFOLIO_THM_ALLOWED_HOSTS=tryhackme.com,www.tryhackme.com,api.tryhackme.com
PORTFOLIO_THM_TOKEN=
